#!/bin/bash

# This script generates "fsdata.c" file for uIP 0.9 stack.
# It takes one argument - name of vendor directory,
# which should contains all www files, at least:
# - index.html (with: <input type="file" name="firmware">)
# - 404.html
# - flashing.hmtl
# - fail.html
#
# Files are processed with dedicated tools and then compressed with gzip -9n.
# HTML files with embedded JS/CSS are processed with careful preservation of styling.
# You SHOULDN'T embed addresses of any external
# files in "flashing.html" file, because web server,
# after receive POST data, returns this page and stops.

# ===== DEBUG MODE CONFIGURATION =====
# Set debug_mode to 1 to enable debug output and retain intermediate files
# Set debug_mode to 0 to disable debug output (no intermediate files saved)
debug_mode=1
# ====================================

# Parse arguments (command line argument overrides the default setting)
vendor_dir=${1:-pig}

# Check for debug flag in command line (overrides the default setting)
if [[ "$2" == "-d" || "$2" == "--debug" ]]; then
    debug_mode=1
    echo "Debug mode enabled via command line: intermediate files will be retained for inspection"
elif [ $debug_mode -eq 1 ]; then
    echo "Debug mode enabled via configuration: intermediate files will be retained for inspection"
fi

# Vendor specific directory (default: "pig")

# Temporary files
files_content_tmp="vendors/.files_content"
files_list_tmp="vendors/.files_list"

# Debug directories for intermediate files
if [ $debug_mode -eq 1 ]; then
    debug_dir="vendors/debug_output"
    minified_dir="$debug_dir/minified"
    gziped_dir="$debug_dir/gziped"
    mkdir -p "$minified_dir" "$gziped_dir"
    echo "Debug output directories:"
    echo "  - Minified files: $minified_dir"
    echo "  - Gzip compressed files: $gziped_dir"
fi

# Enable better error handling
set -e

# Function to check Node.js module availability
check_node_module() {
	local module=$1
	local version_var=$2

	if command -v node >/dev/null 2>&1; then
		# Try multiple methods to find the module
		if node -e "try { require.resolve('$module'); console.log('found'); } catch(e) { process.exit(1); }" 2>/dev/null; then
			eval "$version_var=1"
			echo "Node module '$module' found"
			return 0
		else
			# Try common global paths
			for node_path in /usr/lib/node_modules \
						   /usr/local/lib/node_modules \
						   $HOME/.npm-global/lib/node_modules \
						   $HOME/node_modules; do
				if [ -d "$node_path/$module" ]; then
					export NODE_PATH="$node_path:${NODE_PATH:-}"
					eval "$version_var=1"
					echo "Node module '$module' found at $node_path"
					return 0
				fi
			done
		fi
	fi

	eval "$version_var=0"
	echo "Warning: Node module '$module' not available, using fallback methods"
	return 1
}

# Check for Node.js and modules
echo "Checking build tools..."

# Check Node.js availability
node_available=0
if command -v node >/dev/null 2>&1; then
	node_available=1
	echo "Node.js found: $(node --version)"

	# Show NODE_PATH if set
	if [ -n "$NODE_PATH" ]; then
		echo "NODE_PATH: $NODE_PATH"
	fi
else
	echo "Warning: Node.js not found, using basic compression only"
fi

# Check for specific tools
html_minifier_available=0
css_minifier_available=0
js_minifier_available=0

if [ $node_available -eq 1 ]; then
	# Check for html-minifier (try both names)
	if check_node_module "html-minifier" "html_minifier_available"; then
		html_minifier_available=1
	elif check_node_module "html-minifier-terser" "html_minifier_available"; then
		html_minifier_available=1
		# Create alias if needed
		mkdir -p node_modules
		ln -sf $(dirname $(node -e "console.log(require.resolve('html-minifier-terser'))" 2>/dev/null)) node_modules/html-minifier 2>/dev/null || true
	fi

	# Check for clean-css
	check_node_module "clean-css" "css_minifier_available"

	# Check for terser
	check_node_module "terser" "js_minifier_available"
fi

# Summary of available tools
echo "Tool availability:"
echo "  - HTML Minifier: $([ $html_minifier_available -eq 1 ] && echo "Yes" || echo "No")"
echo "  - CSS Minifier: $([ $css_minifier_available -eq 1 ] && echo "Yes" || echo "No")"
echo "  - JS Minifier: $([ $js_minifier_available -eq 1 ] && echo "Yes" || echo "No")"

# Previous fsdata_file var name
prev_fsdata_struct="NULL"

# Files counter
files_counter=0

# Change ASCII to bytes, comma separated (e.g. "0x01, 0x02, 0x03...")
function ascii_to_bytes() {
	echo -ne "$1" | od -A n -t x1 | tr -d '\n\r ' | sed 's/../0x&,/g;s/,$//'
}

# Compress data using gzip and convert to hex
# Returns: compressed data in hex format
# Also saves compressed file to gziped directory if in debug mode
function compress_and_convert() {
	local _input_file="$1"
	local _original_filename="$2"  # Original filename for debug output
	local _compressed_data
	local _temp_gz=$(mktemp)

	# Compress to temporary file
	gzip -c9n "$_input_file" > "$_temp_gz"

	# Convert to hex
	_compressed_data=$(cat "$_temp_gz" | od -A n -t x1 | tr -d '\n\r ' | sed 's/../0x&,/g;s/,$//')

	# In debug mode, save the compressed file with original name + .gz
	if [ $debug_mode -eq 1 ] && [ -n "$_original_filename" ]; then
		local debug_filename="$(basename "$_original_filename")"
		# Handle different file extensions
		case "$debug_filename" in
			*.html|*.htm|*.css|*.js)
				debug_filename="${debug_filename}.gz"
				;;
			*)
				debug_filename="${debug_filename}.gz"
				;;
		esac
		cp "$_temp_gz" "$gziped_dir/$debug_filename"
		# Send debug output to stderr, not stdout, to avoid polluting fsdata.c
		echo "Debug: Saved gzip compressed file to $gziped_dir/$debug_filename" >&2
	fi

	# Clean up temp file
	rm -f "$_temp_gz"

	echo "$_compressed_data"
}

# Advanced HTML minification with careful preservation of styling
function minify_html_with_preserved_styling() {
	local _input_file="$1"
	local _output_file="$2"
	local _original_filename="$3"  # Original filename for debug output

	if [ $html_minifier_available -eq 1 ]; then
		# Send progress info to stderr
		echo "Minifying HTML: $(basename $_input_file)" >&2

		# Use node with async/await in an immediately-invoked function
		node -e "
		const fs = require('fs');

		(async function() {
			try {
				// Try to load the minifier
				let htmlMinifier;
				try {
					htmlMinifier = require('html-minifier');
				} catch (e) {
					htmlMinifier = require('html-minifier-terser');
				}

				// Read the file
				const content = fs.readFileSync('$_input_file', 'utf8');

				// Minify (await the promise)
				const result = await htmlMinifier.minify(content, {
					collapseWhitespace: true,
					removeComments: true,
					minifyCSS: true,
					minifyJS: true,
					removeRedundantAttributes: false,
					removeScriptTypeAttributes: false,
					removeStyleLinkTypeAttributes: false,
					sortAttributes: false,
					sortClassName: false,
					preserveLineBreaks: false,
					collapseBooleanAttributes: true,
					removeEmptyAttributes: true,
					minifyJS: {
						compress: { drop_console: true },
						mangle: true
					},
					minifyCSS: {
						level: {
							1: { all: true },
							2: { all: false }
						}
					}
				});

				// Write the result
				fs.writeFileSync('$_output_file', result);
				console.error('HTML minification successful');
			} catch (e) {
				console.error('HTML minification failed:', e.message);
				// Fallback: copy original file
				fs.copyFileSync('$_input_file', '$_output_file');
			}
		})().catch(e => {
			console.error('Unhandled error:', e.message);
			fs.copyFileSync('$_input_file', '$_output_file');
		});
		" 2>/dev/null || true
	else
		# No dedicated tool available, copy original file
		cp "$_input_file" "$_output_file"
	fi

	# In debug mode, save the minified file with original name (without _minified suffix)
	if [ $debug_mode -eq 1 ] && [ -n "$_original_filename" ]; then
		local debug_filename="$(basename "$_original_filename")"
		cp "$_output_file" "$minified_dir/$debug_filename"
		# Send debug output to stderr
		echo "Debug: Saved minified HTML to $minified_dir/$debug_filename" >&2
	fi
}

# Separate JS minification for standalone JS files
function minify_standalone_js() {
	local _input_file="$1"
	local _output_file="$2"
	local _original_filename="$3"  # Original filename for debug output

	if [ $js_minifier_available -eq 1 ]; then
		# Send progress info to stderr
		echo "Minifying JS: $(basename $_input_file)" >&2
		node -e "
		try {
			var Terser = require('terser');
			var fs = require('fs');
			var content = fs.readFileSync('$_input_file', 'utf8');
			var result = Terser.minify(content, {
				compress: {drop_console: true},
				mangle: true
			});
			if (result.code) {
				fs.writeFileSync('$_output_file', result.code);
				console.error('JS minification successful');
			} else {
				throw new Error('Minification failed');
			}
		} catch(e) {
			console.error('JS minification failed:', e.message);
			fs.copyFileSync('$_input_file', '$_output_file');
		}
		" 2>/dev/null || true
	else
		# No dedicated tool available, copy original file
		cp "$_input_file" "$_output_file"
	fi

	# In debug mode, save the minified file with original name (without _minified suffix)
	if [ $debug_mode -eq 1 ] && [ -n "$_original_filename" ]; then
		local debug_filename="$(basename "$_original_filename")"
		cp "$_output_file" "$minified_dir/$debug_filename"
		# Send debug output to stderr
		echo "Debug: Saved minified JS to $minified_dir/$debug_filename" >&2
	fi
}

# Advanced CSS minification for standalone CSS files
function minify_standalone_css() {
	local _input_file="$1"
	local _output_file="$2"
	local _original_filename="$3"  # Original filename for debug output

	if [ $css_minifier_available -eq 1 ]; then
		# Send progress info to stderr
		echo "Minifying CSS: $(basename $_input_file)" >&2
		node -e "
		try {
			var CleanCSS = require('clean-css');
			var fs = require('fs');
			var content = fs.readFileSync('$_input_file', 'utf8');
			var result = new CleanCSS({
				level: {
					1: {all: true},
					2: {
						all: false,
						mergeIntoShorthands: false,
						mergeMediaQueries: false
					}
				},
				format: false
			}).minify(content);
			if (result.styles) {
				fs.writeFileSync('$_output_file', result.styles);
				console.error('CSS minification successful');
			} else {
				throw new Error('Minification failed');
			}
		} catch(e) {
			console.error('CSS minification failed:', e.message);
			fs.copyFileSync('$_input_file', '$_output_file');
		}
		" 2>/dev/null || true
	else
		# No dedicated tool available, copy original file
		cp "$_input_file" "$_output_file"
	fi

	# In debug mode, save the minified file with original name (without _minified suffix)
	if [ $debug_mode -eq 1 ] && [ -n "$_original_filename" ]; then
		local debug_filename="$(basename "$_original_filename")"
		cp "$_output_file" "$minified_dir/$debug_filename"
		# Send debug output to stderr
		echo "Debug: Saved minified CSS to $minified_dir/$debug_filename" >&2
	fi
}

# $1 -> file path
function print_data_array() {
	local _file_path="$1"
	local _file_ext="${_file_path##*.}"
	local _file_name="${_file_path##*/}"
	local _file_name_no_ext="${_file_name%\.*}"
	local _file_content=""
	local _is_compressed=0
	local _temp_minified=""
	local _temp_gz=""

	# Send progress info to stderr
	echo "Processing: $_file_name" >&2

	# Open variable declaration
	echo -n "static const char data_${_file_name_no_ext}_${_file_ext}[] = {" >> "$files_content_tmp"

	# HTTP header (200 OK or 404 Not Found)
	if [ "$_file_name_no_ext" == "404" ]; then
		ascii_to_bytes "HTTP/1.0 404 File not found\r\n" >> "$files_content_tmp"
	else
		ascii_to_bytes "HTTP/1.0 200 OK\r\n" >> "$files_content_tmp"
	fi
	echo -n "," >> "$files_content_tmp"

	ascii_to_bytes "Server: uIP/0.9\r\n" >> "$files_content_tmp"
	echo -n "," >> "$files_content_tmp"

	# Content - Process with dedicated tools and then gzip
	case "$_file_ext" in
		css)
			_temp_minified=$(mktemp)

			minify_standalone_css "$_file_path" "$_temp_minified" "$_file_name"
			_file_content=$(compress_and_convert "$_temp_minified" "$_file_name")

			_is_compressed=1
			ascii_to_bytes "Content-type: text/css; charset=UTF-8\r\n" >> "$files_content_tmp"
			;;
		js)
			_temp_minified=$(mktemp)

			minify_standalone_js "$_file_path" "$_temp_minified" "$_file_name"
			_file_content=$(compress_and_convert "$_temp_minified" "$_file_name")

			_is_compressed=1
			ascii_to_bytes "Content-Type: application/javascript\r\n" >> "$files_content_tmp"
			;;
		html|htm)
			_temp_minified=$(mktemp)

			minify_html_with_preserved_styling "$_file_path" "$_temp_minified" "$_file_name"
			_file_content=$(compress_and_convert "$_temp_minified" "$_file_name")

			_is_compressed=1
			ascii_to_bytes "Content-type: text/html; charset=UTF-8\r\n" >> "$files_content_tmp"
			;;
		png|jpg|jpeg|gif|ico|svg)
			# For images, we still compress but don't process with tools
			_file_content=$(compress_and_convert "$_file_path" "$_file_name")

			_is_compressed=1
			case "$_file_ext" in
				png)  ascii_to_bytes "Content-Type: image/png\r\n" >> "$files_content_tmp" ;;
				jpg|jpeg) ascii_to_bytes "Content-Type: image/jpeg\r\n" >> "$files_content_tmp" ;;
				gif)  ascii_to_bytes "Content-Type: image/gif\r\n" >> "$files_content_tmp" ;;
				ico)  ascii_to_bytes "Content-Type: image/x-icon\r\n" >> "$files_content_tmp" ;;
				svg)  ascii_to_bytes "Content-Type: image/svg+xml\r\n" >> "$files_content_tmp" ;;
			esac
			;;
		*)
			# For other files, we compress but don't process with tools
			_file_content=$(compress_and_convert "$_file_path" "$_file_name")

			_is_compressed=1
			ascii_to_bytes "Content-type: text/plain; charset=UTF-8\r\n" >> "$files_content_tmp"
			;;
	esac

	# Add Content-Encoding header if compressed
	if [ $_is_compressed -eq 1 ]; then
		echo -n "," >> "$files_content_tmp"
		ascii_to_bytes "Content-Encoding: gzip\r\n" >> "$files_content_tmp"
	fi

	echo -n "," >> "$files_content_tmp"
	ascii_to_bytes "\r\n" >> "$files_content_tmp"
	echo -n "," >> "$files_content_tmp"

	# File content
	echo -n "$_file_content" >> "$files_content_tmp"

	# And close declaration
	echo -n ",0};" >> "$files_content_tmp"

	# Add a newline after each data array
	echo "" >> "$files_content_tmp"

	# Clean up temporary files
	[ -n "$_temp_minified" ] && rm -f "$_temp_minified"

	# Send completion info to stderr
	echo "Processed: $_file_name" >&2
}

# $1 -> file path
function print_data_struct() {
	local _file_ext="${1##*.}"
	local _file_name="${1##*/}"
	local _file_name_no_ext="${_file_name%\.*}"

	echo -n "const struct fsdata_file file_${_file_name_no_ext}_${_file_ext}[]={{$prev_fsdata_struct,\"/$_file_name_no_ext.$_file_ext\",data_${_file_name_no_ext}_${_file_ext},(int)sizeof(data_${_file_name_no_ext}_${_file_ext})-1}};" >> "$files_list_tmp"
	echo "" >> "$files_list_tmp"

	prev_fsdata_struct="file_${_file_name_no_ext}_${_file_ext}"
}

# === Main loop ===

echo "Starting fsdata.c generation for vendor: $vendor_dir" >&2

if [ -d "vendors/$vendor_dir" ]; then # If vendor dir exists
	# Remove old fsdata.c
	if [ -f "fsdata.c" ]; then
		rm -f "fsdata.c"
		echo "Removed old fsdata.c" >&2
	fi

	# Create temporary files
	touch "$files_content_tmp" "$files_list_tmp"

	# Loop through all files in vendor dir (sort for consistency)
	files_processed=0
	for file in $(ls -1 "vendors/$vendor_dir"/* 2>/dev/null | sort); do
		if [ -f "$file" ]; then
			print_data_array "$file"
			print_data_struct "$file"
			files_processed=$((files_processed+1))
		fi
	done

	if [ $files_processed -eq 0 ]; then
		echo "Warning: No files found in vendors/$vendor_dir" >&2
		rm -f "$files_content_tmp" "$files_list_tmp"
		exit 1
	fi

	# Add required defines
	echo "#define FS_ROOT $prev_fsdata_struct" >> "$files_list_tmp"
	echo "#define FS_NUMFILES $files_processed" >> "$files_list_tmp"

	# Generate new fsdata.c
	cat "$files_content_tmp" > "fsdata.c"
	cat "$files_list_tmp" >> "fsdata.c"

	# Clean up
	rm -f "$files_content_tmp" "$files_list_tmp"

	echo "Successfully generated fsdata.c with $files_processed files" >&2
	echo "FS_ROOT: $prev_fsdata_struct" >&2
	echo "FS_NUMFILES: $files_processed" >&2

	# Show file size
	if [ -f "fsdata.c" ]; then
		echo "fsdata.c size: $(wc -l < fsdata.c) lines, $(du -h fsdata.c | cut -f1)" >&2
	fi

	# Show compression statistics for debug mode
	if [ $debug_mode -eq 1 ] && [ -d "$minified_dir" ] && [ -d "$gziped_dir" ]; then
		echo "" >&2
		echo "Compression Statistics:" >&2
		echo "----------------------" >&2
		for minified_file in "$minified_dir"/*; do
			if [ -f "$minified_file" ]; then
				base_filename=$(basename "$minified_file")
				gz_file="$gziped_dir/${base_filename}.gz"
				if [ -f "$gz_file" ]; then
					minified_size=$(stat -c %s "$minified_file" 2>/dev/null || stat -f %z "$minified_file" 2>/dev/null)
					gz_size=$(stat -c %s "$gz_file" 2>/dev/null || stat -f %z "$gz_file" 2>/dev/null)
					if [ -n "$minified_size" ] && [ -n "$gz_size" ]; then
						ratio=$((100 - (gz_size * 100 / minified_size)))
						printf "%-30s: %6d bytes -> %6d bytes (%d%% reduction)\n" \
							"$base_filename" "$minified_size" "$gz_size" "$ratio" >&2
					fi
				fi
			fi
		done
		echo "" >&2
		echo "Debug mode: Processed files saved to:" >&2
		echo "  - Minified files: $minified_dir/ (original filenames)" >&2
		echo "  - Gzip compressed files: $gziped_dir/ (original filenames + .gz)" >&2
	fi

	if [ $debug_mode -eq 0 ]; then
		echo "Debug mode is disabled (set debug_mode=1 at the top of script to enable)" >&2
	fi
else
	echo "Error! Vendor specific directory (vendors/$vendor_dir) doesn't exist!" >&2
	exit 1
fi